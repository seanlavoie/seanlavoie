{
  "name": "personal-site",
  "private": true,
  "version": "0.0.1",
  "description": "Personal brand monorepo — portfolio and blog",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev:portfolio": "pnpm --filter portfolio dev",
    "dev:blog": "pnpm --filter blog dev",
    "build:portfolio": "pnpm --filter portfolio build",
    "build:blog": "pnpm --filter blog build",
    "build": "pnpm --filter './apps/*' build",
    "preview:portfolio": "pnpm --filter portfolio preview",
    "preview:blog": "pnpm --filter blog preview",
    "check": "pnpm --filter './apps/*' check",
    "lint": "pnpm --filter './apps/*' lint"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1"
  }
}
