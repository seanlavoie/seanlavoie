---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group border-b border-slate-800/60 py-8 last:border-0">
  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <time
      datetime={pubDate.toISOString()}
      class="shrink-0 font-mono text-xs text-slate-500 sm:w-28 sm:pt-1"
    >
      {formattedDate}
    </time>
    <div class="flex-1">
      <a href={`${base}posts/${post.slug}`} class="block group-hover:text-brand-300 transition-colors">
        <h2 class="text-lg font-semibold text-slate-100 mb-2">{title}</h2>
        <p class="text-sm text-slate-400 leading-relaxed mb-3">{description}</p>
      </a>
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <a
            href={`${base}tags/${tag}`}
            class="rounded-md bg-slate-800/80 px-2 py-0.5 font-mono text-xs text-slate-500 hover:text-slate-300 transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    </div>
  </div>
</article>
